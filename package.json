{
  "name": "tweakpane-monorepo",
  "version": "4.0.5",
  "private": true,
  "description": "Tweakpane monorepo",
  "author": "cocopon",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "prettier": "./prettier.config.js",
  "scripts": {
    "clean": "rimraf .nyc_output test",
    "coverage": "run-s coverage:prepare coverage:package coverage:merge coverage:report",
    "coverage:merge": "run-s coverage:merge:*",
    "coverage:merge:core": "nyc merge packages/core/.nyc_output .nyc_output/core.json",
    "coverage:merge:tweakpane": "nyc merge packages/tweakpane/.nyc_output .nyc_output/tweakpane.json",
    "coverage:package": "run-s coverage:package:*",
    "coverage:package:core": "pnpm -C packages/core run coverage",
    "coverage:package:tweakpane": "pnpm -C packages/tweakpane run coverage",
    "coverage:prepare": "mkdirp .nyc_output",
    "coverage:report": "nyc report --reporter=lcov",
    "lint": "pnpm -C packages/core run lint && pnpm -C packages/tweakpane run lint",
    "setup": "run-s setup:core setup:tweakpane",
    "setup:core": "pnpm -C packages/core run build",
    "setup:tweakpane": "pnpm -C packages/tweakpane run main:prepare"
  },
  "devDependencies": {
    "@types/assert": "^1.5.4",
    "@types/jsdom": "^16.2.13",
    "@types/mocha": "^9.1.1",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^5.33.0",
    "@typescript-eslint/parser": "^5.33.0",
    "assert": "^2.0.0",
    "autoprefixer": "^9.1.5",
    "eslint": "^7.26.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "jsdom": "^16.7.0",
    "mkdirp": "^1.0.4",
    "mocha": "^10.2.0",
    "npm-run-all": "^4.1.5",
    "nyc": "^15.1.0",
    "onchange": "^7.1.0",
    "prettier": "^2.4.0",
    "rimraf": "^3.0.2",
    "sass": "^1.58.0",
    "ts-node": "^10.9.1",
    "tslib": "^2.1.0",
    "typescript": "~5.9.0"
  }
}
